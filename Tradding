  const inp=document.getElementById('rule-input');
  const v=inp.value.trim();if(!v)return;
  rules.push(v);inp.value='';save();renderRules();
}
function deleteRule(i){if(confirm('Smazat pravidlo?')){rules.splice(i,1);save();renderRules();}}

// ─── EXPORT CSV ──────────────────────────────────────
function exportCSV(){
  const cols=['date','time','asset','type','dir','tf','entry','exit','sl','tp','size','pipval','pnl','rr','result','setup','conf','prop','session','mood','rules','good','bad','notes'];
  const hdr=cols.join(',');
  const rows=trades.map(t=>cols.map(c=>{
    let v=t[c];
    if(Array.isArray(v))v=v.join('; ');
    if(v===undefined||v===null)v='';
    return '"'+String(v).replace(/"/g,'""')+'"';
  }).join(','));
  const csv=[hdr,...rows].join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download='tradelog_'+new Date().toISOString().split('T')[0]+'.csv';a.click();
}

// ─── INIT ────────────────────────────────────────────
setDef();
renderDashboard();
