    </div>
    <div class="sc" style="--sc-c:var(--accent2)">
      <div class="sc-label">Win rate</div>
      <div class="sc-val" style="color:var(--accent2)">${wr}%</div>
      <div class="sc-sub">Avg W: +${avgWin.toFixed(2)}$ | L: -${avgLoss.toFixed(2)}$</div>
    </div>
    <div class="sc" style="--sc-c:${pf>=1?'var(--green)':'var(--red)'}">
      <div class="sc-label">Profit factor</div>
      <div class="sc-val" style="color:${pf>=1?'var(--green)':'var(--red)'}">${isFinite(pf)?pf.toFixed(2):'∞'}</div>
      <div class="sc-sub">+${grossP.toFixed(2)} / -${grossL.toFixed(2)}$</div>
    </div>
    <div class="sc" style="--sc-c:${exp>=0?'var(--green)':'var(--red)'}">
      <div class="sc-label">Expectancy</div>
      <div class="sc-val" style="color:${exp>=0?'var(--green)':'var(--red)'}">${exp>=0?'+':''}${exp.toFixed(2)}$</div>
      <div class="sc-sub">Hodnota / obchod</div>
    </div>
    <div class="sc" style="--sc-c:var(--red)">
