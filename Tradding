// ─── UTILS ──────────────────────────────────────────
function r2(n){return Math.round(n*100)/100;}
function r4(n){return Math.round(n*10000)/10000;}

// Exact R:R = |TP-entry| / |entry-SL|
function calcRR(e,sl,tp){
  if(!e||!sl||!tp||sl===e)return null;
  return r2(Math.abs(tp-e)/Math.abs(e-sl));
}

// Exact P&L:
// Forex: pips = rawMove / pipSize; pnl = pips * pipval * size
// Non-Forex: pnl = rawMove * size (price difference × units)
function calcPnL(entry,exit,dir,size,pipval,type){
  if(!entry||!exit||!size)return null;
  const direction=dir==='Long'?1:-1;
  const rawMove=(exit-entry)*direction;
  if(type==='Forex'){
    const pipSize=entry>10?0.01:0.0001; // JPY pairs vs others
    const pips=rawMove/pipSize;
    const pv=pipval>0?pipval:10;
    return r2(pips*pv*size);
  }
  return r2(rawMove*size);
}

