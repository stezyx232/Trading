function renderDashboard(){
  const T=periodFilter(trades).slice().sort((a,b)=>a.date.localeCompare(b.date));
  const n=T.length;
  const wins=T.filter(t=>t.result==='Win');
  const losses=T.filter(t=>t.result==='Loss');
  const bes=T.filter(t=>t.result==='Breakeven');

  const totalPnl=r2(T.reduce((s,t)=>s+t.pnl,0));
  const wr=n?Math.round(wins.length/n*100):0;
  const avgWin=wins.length?r2(wins.reduce((s,t)=>s+t.pnl,0)/wins.length):0;
  const avgLoss=losses.length?r2(Math.abs(losses.reduce((s,t)=>s+t.pnl,0)/losses.length)):0;
  const grossP=r2(wins.reduce((s,t)=>s+t.pnl,0));
  const grossL=r2(Math.abs(losses.reduce((s,t)=>s+t.pnl,0)));
  const pf=grossL>0?r2(grossP/grossL):(grossP>0?Infinity:0);
  const wr2=n?wins.length/n:0;const lr2=n?losses.length/n:0;
  const exp=r2(wr2*avgWin-lr2*avgLoss);

  // Max Drawdown (peak-to-trough)
  let cum=0,peak=0,maxDD=0;
  T.forEach(t=>{cum=r2(cum+t.pnl);if(cum>peak)peak=cum;const dd=r2(peak-cum);if(dd>maxDD)maxDD=dd;});

  const rrVals=T.filter(t=>t.rr).map(t=>parseFloat(t.rr));
  const avgRR=rrVals.length?r2(rrVals.reduce((a,b)=>a+b,0)/rrVals.length):null;
  let curS=0;for(let i=T.length-1;i>=0;i--){if(T[i].result==='Win')curS++;else break;}

  document.getElementById('main-stats').innerHTML=`
