function saveTrade(){
  const asset=document.getElementById('n-asset').value.trim();
  if(!asset){alert('Zadej aktivum!');return;}

  const entry=parseFloat(document.getElementById('n-entry').value)||0;
  const exit=parseFloat(document.getElementById('n-exit').value)||0;
  const sl=parseFloat(document.getElementById('n-sl').value)||0;
  const tp=parseFloat(document.getElementById('n-tp').value)||0;
  const size=parseFloat(document.getElementById('n-size').value)||1;
  const pipval=parseFloat(document.getElementById('n-pipval').value)||10;
  const dir=document.getElementById('n-dir').value;
  const type=document.getElementById('n-type').value;

  const rr=(entry&&sl&&tp)?calcRR(entry,sl,tp):null;

  let pnlManual=parseFloat(document.getElementById('n-pnl').value);
  let pnl;
  if(!isNaN(pnlManual)){pnl=r2(pnlManual);}
  else if(entry&&exit){pnl=calcPnL(entry,exit,dir,size,pipval,type)||0;}
  else{pnl=0;}

  trades.push({
    date:document.getElementById('n-date').value,
    time:document.getElementById('n-time').value,
    asset,type,dir,
    tf:document.getElementById('n-tf').value,
    entry:r4(entry),exit:r4(exit),sl:r4(sl),tp:r4(tp),
    size,pipval,pnl,
    rr:rr!==null?rr.toFixed(2):'',
    result:document.getElementById('n-result').value,
    setup:document.getElementById('n-setup').value,
    conf:document.getElementById('n-conf').value,
    mood:[...selMoods],rules:[...selRules],
    good:document.getElementById('n-good').value,
    bad:document.getElementById('n-bad').value,
    notes:document.getElementById('n-notes').value,
    prop:document.getElementById('n-prop').value,
    session:document.getElementById('n-session').value,
  });
  save();clearForm();nav('dashboard');
}

