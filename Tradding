  // Insights
  const sortedT=T.slice().sort((a,b)=>b.pnl-a.pnl);
  const bestT=sortedT[0],worstT=sortedT[sortedT.length-1];
  const sMap2={};T.forEach(t=>{if(t.setup)sMap2[t.setup]=r2((sMap2[t.setup]||0)+t.pnl);});
