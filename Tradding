<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TradeLog — Tvůj trading journal</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0b0c0f;--bg2:#111318;--bg3:#16181f;--bg4:#1c1e27;
  --border:#252830;--border2:#2e3140;
  --accent:#6c63ff;--accent2:#4ecca3;--accent3:#f9a03f;
  --red:#ff4d4f;--green:#3ecf8e;
  --text:#e8eaf0;--text2:#9296a8;--text3:#5a5e70;
  --r:12px;--font:'Sora',sans-serif;--mono:'DM Mono',monospace;
}
html{font-size:14px;}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;line-height:1.6;}
button{font-family:var(--font);cursor:pointer;}
input,select,textarea{font-family:var(--font);}
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}

/* LAYOUT */
.shell{display:flex;height:100vh;overflow:hidden;}
.sidebar{width:216px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;}
.main{flex:1;overflow-y:auto;overflow-x:hidden;}

/* SIDEBAR */
.logo{padding:20px 16px 16px;border-bottom:1px solid var(--border);}
.logo-row{display:flex;align-items:center;gap:9px;}
.logo-icon{width:30px;height:30px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.logo-icon svg{width:15px;height:15px;fill:none;stroke:#fff;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;}
.logo-name{font-size:15px;font-weight:700;letter-spacing:-.3px;}
.logo-sub{font-size:10px;color:var(--text3);font-family:var(--mono);letter-spacing:.5px;margin-top:1px;}
.nav{padding:10px 8px;flex:1;}
.nav-section{margin-bottom:18px;}
.nav-label{font-size:9px;font-weight:600;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;padding:0 8px;margin-bottom:4px;}
.nb{display:flex;align-items:center;gap:9px;width:100%;padding:8px 10px;border-radius:8px;border:none;background:none;color:var(--text2);font-size:12.5px;font-weight:400;transition:all .15s;text-align:left;}
.nb svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
.nb:hover{background:var(--bg3);color:var(--text);}
.nb.active{background:rgba(108,99,255,.12);color:var(--accent);font-weight:500;}
.nb.active svg{stroke:var(--accent);}
.sidebar-footer{padding:12px;border-top:1px solid var(--border);}
.acct{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:10px;}
.acct-av{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;}
.acct-name{font-size:12px;font-weight:500;}
.acct-role{font-size:10px;color:var(--text3);}

/* TOPBAR */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 22px;border-bottom:1px solid var(--border);background:var(--bg2);position:sticky;top:0;z-index:10;}
.page-title{font-size:16px;font-weight:600;letter-spacing:-.3px;}
.topbar-right{display:flex;align-items:center;gap:8px;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:8px;font-size:12px;font-weight:500;border:none;cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn svg{width:12px;height:12px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.btn-primary{background:var(--accent);color:#fff;}.btn-primary:hover{opacity:.88;}
.btn-ghost{background:var(--bg3);color:var(--text2);border:1px solid var(--border);}.btn-ghost:hover{color:var(--text);background:var(--bg4);}

/* CONTENT */
.content{padding:20px 22px;}
.tab{display:none;animation:fi .18s ease;}
.tab.active{display:block;}
@keyframes fi{from{opacity:0;transform:translateY(3px);}to{opacity:1;transform:translateY(0);}}

/* STATS GRID */
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(145px,1fr));gap:10px;margin-bottom:18px;}
.sc{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;position:relative;overflow:hidden;}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--sc-c,var(--accent));opacity:.7;}
.sc-label{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:7px;}
.sc-val{font-size:22px;font-weight:700;font-family:var(--mono);letter-spacing:-.5px;line-height:1;}
.sc-sub{font-size:10px;color:var(--text3);margin-top:4px;font-family:var(--mono);}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);margin-bottom:14px;}
.ch{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.ct{font-size:10px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--text2);}
.cb{padding:18px;}
.g2{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px;}
.g2e{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}

/* TABLE */
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:12px;}
th{text-align:left;padding:9px 11px;font-size:9.5px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none;}
th:hover{color:var(--text2);}
td{padding:10px 11px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;white-space:nowrap;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--bg3);}
.mono{font-family:var(--mono);}

/* BADGES */
.badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;}
.bwin{background:rgba(62,207,142,.1);color:var(--green);border:1px solid rgba(62,207,142,.2);}
.bloss{background:rgba(255,77,79,.1);color:var(--red);border:1px solid rgba(255,77,79,.2);}
.bbe{background:rgba(249,160,63,.1);color:var(--accent3);border:1px solid rgba(249,160,63,.2);}
.blong{background:rgba(78,204,163,.08);color:var(--accent2);border:1px solid rgba(78,204,163,.2);}
.bshort{background:rgba(255,77,79,.08);color:var(--red);border:1px solid rgba(255,77,79,.2);}
.btype{background:var(--bg3);color:var(--text2);border:1px solid var(--border);}

/* FORM */
.fsec{margin-bottom:22px;}
.fsec-title{font-size:9.5px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.fsec-title::after{content:'';flex:1;height:1px;background:var(--border);}
.fg{display:grid;grid-template-columns:repeat(auto-fit,minmax(145px,1fr));gap:9px;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.field label{display:block;font-size:9.5px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:4px;}
.field input,.field select,.field textarea{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 10px;color:var(--text);font-size:12.5px;outline:none;transition:border-color .15s;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent);}
.field input::placeholder{color:var(--text3);}
.field select option{background:var(--bg2);}
.field textarea{resize:vertical;min-height:68px;line-height:1.5;}
.field.ro input{background:var(--bg4);color:var(--accent);font-family:var(--mono);font-weight:500;}
.rr-box{display:flex;align-items:center;gap:8px;background:rgba(108,99,255,.07);border:1px solid rgba(108,99,255,.18);border-radius:10px;padding:12px 16px;margin-bottom:20px;}
.rr-box-label{font-size:11px;color:var(--text3);}
.rr-val{font-family:var(--mono);font-size:22px;font-weight:600;color:var(--accent);margin-left:auto;}
.pnl-val{font-family:var(--mono);font-size:13px;margin-left:10px;}

/* CHIPS */
.chips{display:flex;flex-wrap:wrap;gap:5px;}
.chip{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:500;border:1px solid var(--border);background:var(--bg3);color:var(--text2);cursor:pointer;transition:all .14s;user-select:none;}
.chip:hover{border-color:var(--border2);color:var(--text);}
.chip.ms{background:rgba(108,99,255,.1);border-color:rgba(108,99,255,.35);color:var(--accent);}
.chip.rs{background:rgba(255,77,79,.08);border-color:rgba(255,77,79,.25);color:var(--red);}

/* FILTER BAR */
.fbar{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:14px;}
.fbar select,.fbar input{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:6px 9px;color:var(--text);font-size:11.5px;outline:none;font-family:var(--font);}
.fbar select:focus,.fbar input:focus{border-color:var(--accent);}
.fbar select option{background:var(--bg2);}

/* PROGRESS */
.prog{height:3px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-top:5px;}
.prog-fill{height:100%;border-radius:2px;transition:width .4s ease;}

/* INSIGHTS */
.irow{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:10px;margin-bottom:14px;}
.ins{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:13px 15px;}
.ins-label{font-size:9.5px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:5px;}
.ins-val{font-size:17px;font-weight:700;font-family:var(--mono);}
.ins-sub{font-size:10px;color:var(--text3);margin-top:2px;font-family:var(--mono);}

/* RULE ITEMS */
.rule-item{display:flex;align-items:center;gap:11px;padding:11px 0;border-bottom:1px solid var(--border);}
.rule-item:last-child{border-bottom:none;}
.rule-num{width:22px;height:22px;border-radius:6px;background:rgba(108,99,255,.09);border:1px solid rgba(108,99,255,.18);color:var(--accent);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.del-btn{background:none;border:none;cursor:pointer;color:var(--text3);padding:3px 7px;border-radius:5px;font-size:12px;transition:all .14s;}
.del-btn:hover{background:rgba(255,77,79,.1);color:var(--red);}

/* EMPTY */
.empty{text-align:center;padding:44px 20px;color:var(--text3);font-size:12px;}
canvas{display:block;}
</style>
</head>
<body>
<div class="shell">

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-row">
      <div class="logo-icon">
        <svg viewBox="0 0 16 16"><polyline points="1 11 5 6 9 9 13 3"/><circle cx="13" cy="3" r="1.5" fill="white" stroke="none"/></svg>
      </div>
      <div>
        <div class="logo-name">TradeLog</div>
        <div class="logo-sub">Trading Journal</div>
      </div>
    </div>
  </div>
  <nav class="nav">
    <div class="nav-section">
      <div class="nav-label">Přehled</div>
      <button class="nb active" onclick="nav('dashboard')">
        <svg viewBox="0 0 16 16"><rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/><rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/></svg>Dashboard
      </button>
      <button class="nb" onclick="nav('stats')">
        <svg viewBox="0 0 16 16"><line x1="1" y1="15" x2="1" y2="5"/><line x1="5" y1="15" x2="5" y2="8"/><line x1="9" y1="15" x2="9" y2="3"/><line x1="13" y1="15" x2="13" y2="6"/><line x1="0" y1="15" x2="16" y2="15"/></svg>Statistiky
      </button>
    </div>
    <div class="nav-section">
      <div class="nav-label">Obchody</div>
      <button class="nb" onclick="nav('new')">
        <svg viewBox="0 0 16 16"><circle cx="8" cy="8" r="7"/><line x1="8" y1="5" x2="8" y2="11"/><line x1="5" y1="8" x2="11" y2="8"/></svg>Nový obchod
      </button>
      <button class="nb" onclick="nav('journal')">
        <svg viewBox="0 0 16 16"><rect x="2" y="1" width="12" height="14" rx="1.5"/><line x1="5" y1="5" x2="11" y2="5"/><line x1="5" y1="8" x2="11" y2="8"/><line x1="5" y1="11" x2="9" y2="11"/></svg>Journal
      </button>
    </div>
    <div class="nav-section">
      <div class="nav-label">Systém</div>
      <button class="nb" onclick="nav('rules')">
        <svg viewBox="0 0 16 16"><path d="M8 1L2 4v4c0 4 6 7 6 7s6-3 6-7V4z"/><polyline points="5 8 7 10 11 6"/></svg>Pravidla
      </button>
      <button class="nb" onclick="openImport()">
        <svg viewBox="0 0 16 16"><path d="M3 12h10M8 14V6M5 9l3-3 3 3"/></svg>Import MT5/MT4
      </button>
      <button class="nb" onclick="exportCSV()">
        <svg viewBox="0 0 16 16"><path d="M3 12h10M8 2v8M5 7l3 3 3-3"/></svg>Export CSV
      </button>
    </div>
  </nav>
  <div class="sidebar-footer">
    <div class="acct">
      <div class="acct-av">T</div>
      <div><div class="acct-name">Trader</div><div class="acct-role">Pro účet</div></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">

<!-- DASHBOARD -->
<div id="tab-dashboard" class="tab active">
  <div class="topbar">
    <div class="page-title">Dashboard</div>
    <div class="topbar-right">
      <select id="dash-period" onchange="renderDashboard()" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:6px 10px;color:var(--text);font-size:11.5px;outline:none;font-family:var(--font);">
        <option value="all">Celé období</option><option value="30">Posledních 30 dní</option><option value="7">Posledních 7 dní</option>
      </select>
      <button class="btn btn-primary" onclick="nav('new')">
        <svg viewBox="0 0 13 13"><line x1="6.5" y1="1" x2="6.5" y2="12"/><line x1="1" y1="6.5" x2="12" y2="6.5"/></svg>Přidat obchod
      </button>
    </div>
  </div>
  <div class="content">
    <div class="sgrid" id="main-stats"></div>
    <div class="g2">
      <div class="card"><div class="ch"><span class="ct">Equity křivka</span><span id="eq-badge" style="font-family:var(--mono);font-size:12px;"></span></div><div class="cb"><canvas id="c-equity" height="130"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Win / Loss / BE</span></div><div class="cb"><canvas id="c-wl" height="130"></canvas></div></div>
    </div>
    <div class="g3">
      <div class="card"><div class="ch"><span class="ct">P&L podle aktiva</span></div><div class="cb"><canvas id="c-asset" height="140"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">P&L podle dne</span></div><div class="cb"><canvas id="c-weekday" height="140"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Distribuce P&L</span></div><div class="cb"><canvas id="c-dist" height="140"></canvas></div></div>
    </div>
    <div class="irow" id="insights"></div>
    <div class="card">
      <div class="ch"><span class="ct">Posledních 5 obchodů</span><button class="btn btn-ghost" onclick="nav('journal')" style="font-size:11px;padding:5px 10px;">Vše →</button></div>
      <div class="tw"><table><thead><tr><th>Datum</th><th>Aktivum</th><th>Směr</th><th>Setup</th><th>P&L</th><th>R:R</th><th>Výsledek</th><th>Mindset</th></tr></thead><tbody id="recent-tbody"></tbody></table></div>
    </div>
  </div>
</div>

<!-- STATS -->
<div id="tab-stats" class="tab">
  <div class="topbar"><div class="page-title">Pokročilé statistiky</div></div>
  <div class="content">
    <div class="sgrid" id="adv-stats"></div>
    <div class="g2e">
      <div class="card"><div class="ch"><span class="ct">Výkon podle setupu</span></div><div class="cb"><canvas id="c-setup" height="150"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Mindset vs P&L</span></div><div class="cb"><canvas id="c-mood" height="150"></canvas></div></div>
    </div>
    <div class="g3">
      <div class="card"><div class="ch"><span class="ct">Session</span></div><div class="cb"><canvas id="c-session" height="130"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Timeframe</span></div><div class="cb"><canvas id="c-tf" height="130"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Prop firma</span></div><div class="cb"><canvas id="c-prop" height="130"></canvas></div></div>
    </div>
    <div class="g2e">
      <div class="card"><div class="ch"><span class="ct">Měsíční P&L</span></div><div class="cb"><canvas id="c-monthly" height="150"></canvas></div></div>
      <div class="card"><div class="ch"><span class="ct">Long vs Short</span></div><div class="cb" id="ls-detail" style="padding:16px;"></div></div>
    </div>
  </div>
</div>

<!-- NEW TRADE -->
<div id="tab-new" class="tab">
  <div class="topbar"><div class="page-title">Nový obchod</div><div class="topbar-right"><button class="btn btn-ghost" onclick="clearForm()">Vymazat</button></div></div>
  <div class="content">
    <div class="card"><div class="cb">
      <div class="rr-box">
        <div><div class="rr-box-label">Risk : Reward</div><div style="font-size:10px;color:var(--text3);font-family:var(--mono);">auto kalkulace z entry/SL/TP</div></div>
        <div class="rr-val" id="rr-display">—</div>
        <div class="pnl-val" id="pnl-display" style="color:var(--text3);">P&L: —</div>
      </div>

      <div class="fsec"><div class="fsec-title">Základní info</div>
        <div class="fg">
          <div class="field"><label>Datum</label><input type="date" id="n-date"></div>
          <div class="field"><label>Čas vstupu</label><input type="time" id="n-time"></div>
          <div class="field"><label>Aktivum</label><input type="text" id="n-asset" placeholder="EURUSD, BTC, AAPL..."></div>
          <div class="field"><label>Kategorie</label><select id="n-type"><option>Forex</option><option>Krypto</option><option>Akcie</option><option>ETF</option><option>Futures</option><option>Komodity</option></select></div>
          <div class="field"><label>Směr</label><select id="n-dir"><option>Long</option><option>Short</option></select></div>
          <div class="field"><label>Timeframe</label><select id="n-tf"><option>M1</option><option>M5</option><option>M15</option><option>M30</option><option>H1</option><option selected>H4</option><option>D1</option><option>W1</option></select></div>
        </div>
      </div>

      <div class="fsec"><div class="fsec-title">Ceny &amp; pozice</div>
        <div class="fg">
          <div class="field"><label>Entry cena</label><input type="number" id="n-entry" step="any" placeholder="0.00000" oninput="calcAll()"></div>
          <div class="field"><label>Exit cena</label><input type="number" id="n-exit" step="any" placeholder="0.00000" oninput="calcAll()"></div>
          <div class="field"><label>Stop Loss</label><input type="number" id="n-sl" step="any" placeholder="0.00000" oninput="calcAll()"></div>
          <div class="field"><label>Take Profit</label><input type="number" id="n-tp" step="any" placeholder="0.00000" oninput="calcAll()"></div>
          <div class="field"><label>Velikost (loty / ks)</label><input type="number" id="n-size" step="any" placeholder="1.00" oninput="calcAll()"></div>
          <div class="field"><label title="Forex: $/pip/lot (např.10). Ostatní: nechej prázdné">Pip value $/pip (Forex)</label><input type="number" id="n-pipval" step="any" placeholder="10" oninput="calcAll()"></div>
        </div>
        <div class="fg" style="margin-top:8px;">
          <div class="field"><label>P&L ($) — přepsat</label><input type="number" id="n-pnl" step="any" placeholder="auto..."></div>
          <div class="field"><label>Výsledek</label><select id="n-result"><option>Win</option><option>Loss</option><option>Breakeven</option></select></div>
          <div class="field"><label>Prop firma</label><select id="n-prop"><option value="">Vlastní účet</option><option>FTMO</option><option>For Traders</option><option>MyFundedFx</option><option>The5ers</option><option>E8 Funding</option><option>Jiná</option></select></div>
          <div class="field"><label>Session</label><select id="n-session"><option>London</option><option>New York</option><option>Asian</option><option>London–NY Overlap</option><option>Pre-market</option><option>Jiná</option></select></div>
        </div>
      </div>

      <div class="fsec"><div class="fsec-title">Setup &amp; strategie</div>
