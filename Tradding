    options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>'P&L: '+(ctx.parsed.y>=0?'+':'')+ctx.parsed.y.toFixed(2)+'$'}}},scales:{x:{grid:{color:C.g},ticks:{color:C.t,font:{size:10},maxTicksLimit:8}},y:{grid:{color:C.g},ticks:{color:C.t,font:{size:10},callback:v=>v.toFixed(0)+'$'}}}}
  });
  const badge=document.getElementById('eq-badge');
  badge.textContent=(totalPnl>=0?'+':'')+totalPnl.toFixed(2)+'$';
  badge.style.color=totalPnl>=0?'var(--green)':'var(--red)';

  // Donut
  dch('wl');
  _ch['wl']=new Chart(document.getElementById('c-wl'),{
    type:'doughnut',
    data:{labels:['Win','Loss','BE'],datasets:[{data:[wins.length,losses.length,bes.length],backgroundColor:['rgba(62,207,142,0.82)','rgba(255,77,79,0.82)','rgba(249,160,63,0.82)'],borderWidth:0}]},
    options:{responsive:true,cutout:'62%',plugins:{legend:{position:'bottom',labels:{color:C.t,font:{size:11},padding:10,boxWidth:9}}}}
  });

  // Asset P&L
  const aMap={};T.forEach(t=>{aMap[t.asset]=r2((aMap[t.asset]||0)+t.pnl);});
