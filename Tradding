}

function calcAll(){
  const e=parseFloat(document.getElementById('n-entry').value);
  const x=parseFloat(document.getElementById('n-exit').value);
  const sl=parseFloat(document.getElementById('n-sl').value);
  const tp=parseFloat(document.getElementById('n-tp').value);
  const sz=parseFloat(document.getElementById('n-size').value)||1;
  const pv=parseFloat(document.getElementById('n-pipval').value)||10;
  const dir=document.getElementById('n-dir').value;
  const type=document.getElementById('n-type').value;

  const rr=(e&&sl&&tp)?calcRR(e,sl,tp):null;
  document.getElementById('rr-display').textContent=rr!==null?rr.toFixed(2):'—';

  if(e&&x){
    const pnl=calcPnL(e,x,dir,sz,pv,type);
    if(pnl!==null){
      document.getElementById('n-pnl').placeholder=pnl.toFixed(2);
      const el=document.getElementById('pnl-display');
      el.textContent='P&L: '+(pnl>=0?'+':'')+pnl.toFixed(2)+'$';
      el.style.color=pnl>=0?'var(--green)':'var(--red)';
    }
  }
}

['n-entry','n-exit','n-sl','n-tp','n-size','n-pipval','n-dir','n-type'].forEach(id=>{
