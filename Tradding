    <div class="ins"><div class="ins-label">Avg / obchod</div><div class="ins-val" style="color:${exp>=0?'var(--green)':'var(--red)'}">${exp>=0?'+':''}${exp.toFixed(2)}$</div><div class="ins-sub">Expectancy</div></div>
  `;

  // Recent 5
  const rec=trades.slice().sort((a,b)=>b.date.localeCompare(a.date)).slice(0,5);
  document.getElementById('recent-tbody').innerHTML=rec.length?rec.map(t=>{
    const bc=t.result==='Win'?'bwin':t.result==='Loss'?'bloss':'bbe';
