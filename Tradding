      <div class="sc-sub">Avg R:R: ${avgRR!==null?avgRR.toFixed(2):'—'}</div>
    </div>
  `;

  const C=CD();

  // Equity curve
  let c2=0;
  const eqL=T.map(t=>t.date.slice(5));
  const eqD=T.map(t=>{c2=r2(c2+t.pnl);return c2;});
  const eqCol=totalPnl>=0?'#3ecf8e':'#ff4d4f';
  dch('equity');
  _ch['equity']=new Chart(document.getElementById('c-equity'),{
    type:'line',
