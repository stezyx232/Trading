// ─── PERIOD FILTER ───────────────────────────────────
function periodFilter(list){
  const v=document.getElementById('dash-period')?.value||'all';
  if(v==='all')return list;
  const cutoff=new Date();cutoff.setDate(cutoff.getDate()-parseInt(v));
  return list.filter(t=>new Date(t.date)>=cutoff);
}

